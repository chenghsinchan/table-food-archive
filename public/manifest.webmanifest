{
  "name": "TABLE",
  "short_name": "TABLE",
  "description": "A private, image-first food archive.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#F8F6F2",
  "theme_color": "#F8F6F2",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icon-192-v2.png",
      "sizes": "192x192",
